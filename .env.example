# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Backend API URL — used at build time by Vite
# For local dev this points to /api (proxied to http://localhost:3000)
# For production this uses the same domain as the frontend
VITE_API_URL=/api
VITE_SERVER_ORIGIN=http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Security - reCAPTCHA v3
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Public reCAPTCHA v3 key (not sensitive, safe to expose in frontend)
# Get from https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_KEY=your-recaptcha-public-key
